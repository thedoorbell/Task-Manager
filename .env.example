PORT=3000
HOST=0.0.0.0
NODE_ENV=production
# SQLite (local): no DB URL required; production uses Postgres via DATABASE_URL
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Session secret / cookie encryption key (>= 32 chars)
SESSION_KEY=your-secret-key-change-in-production

ROLLBAR_ACCESS_TOKEN=your-rollbar-access-token