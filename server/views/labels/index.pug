extends ../layouts/application.pug

block header
  = t('views.labels.title')

block content
  a.btn.btn-primary(href=route('newLabel'))= t('views.labels.new.create')
  .table-responsive
    table.table.table-borderless.table-striped.mt-5.bg-white
      thead
        tr
          th= t('views.labels.id')
          th= t('views.labels.name')
          th= t('views.labels.createdAt')
          th
      tbody
        each label in labels
          tr
            td= label.id
            td= label.name
            td= formatDate(label.createdAt)
            td
              .d-flex
                a.btn.btn-primary.me-1(href=route('editLabel', { id: label.id }))= t('layouts.edit')
                +buttonTo(route('deleteLabel', { id: label.id }), 'delete')(class="btn btn-danger" value=t('layouts.delete'))