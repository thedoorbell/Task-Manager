extends ../layouts/application.pug

block header
  = t('views.session.new.signIn')

block content
  .row.justify-content-center
    .col-12.col-md-4.mt-3
      .card.shadow-sm
        .card-body
          .col-12.mt-3.mt-mb-0
            +formFor()(action=route('session') method='post')
              +input(signInForm, 'email', errors)(type="text")
              +input(signInForm, 'password')(type="password")
              +submit(signInForm)(value=t('views.session.new.submit'))
